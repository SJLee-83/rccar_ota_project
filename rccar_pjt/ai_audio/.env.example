# SSAFY GMS portal에서 발급받은 키. 따옴표 없이 입력합니다.
GMS_KEY=replace_with_your_gms_key

GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
STT_MODEL=whisper-1
CHAT_MODEL=gpt-5.4-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova

# SPH0645는 일반적으로 48 kHz, 32-bit I2S 프레임을 사용합니다.
RECORD_SECONDS=5
AUDIO_RATE=48000
AUDIO_SAMPLE_BITS=32
AUDIO_CHANNELS=2

# python audio_devices.py 출력에서 SPH0645 입력 장치 번호를 지정합니다.
# 비워 두면 시스템 기본 입력 장치를 사용합니다.
AUDIO_INPUT_DEVICE=

# mpg123의 ALSA 장치명입니다. 비워 두면 시스템 기본 출력을 사용합니다.
# 예: hw:2,0 또는 plughw:2,0
AUDIO_OUTPUT_DEVICE=

REQUEST_TIMEOUT_SECONDS=120
